{
  "info": {
    "name": "Autotrade Sentinel API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"trader@example.com\",\n  \"password\": \"securepass123\",\n  \"username\": \"trader_01\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"trader@example.com\",\n  \"password\": \"securepass123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Webhook",
      "item": [
        {
          "name": "Send Webhook (Entry Long)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/webhook",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"passphrase\": \"your_webhook_secret\",\n  \"event_id\": \"20240115_BTCUSDT_entry\",\n  \"event_type\": \"entry_long\",\n  \"strategy_id\": \"macd_cross_v2\",\n  \"symbol\": \"BINANCE:BTCUSDT\",\n  \"amount\": \"10%\",\n  \"exchange\": \"binance\",\n  \"leverage\": 10\n}"
            }
          }
        },
        {
          "name": "Send Webhook (Exit Long)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/webhook",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"passphrase\": \"your_webhook_secret\",\n  \"event_id\": \"20240115_BTCUSDT_exit\",\n  \"event_type\": \"exit_long\",\n  \"strategy_id\": \"macd_cross_v2\",\n  \"symbol\": \"BTCUSDT\",\n  \"exchange\": \"binance\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Exchange Data",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/exchange-data",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ]
      }
    },
    {
      "name": "Clear History",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/clear-execution-history",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mode\": \"demo\"\n}"
        }
      }
    }
  ]
}
